{
  "name": "vrm-electron",
  "version": "1.0.0",
  "description": "VRM Viewer - Electron + Vite Desktop App",
  "type": "module",
  "main": "electron/main.js",
  "config": {
    "forge": "./forge.config.cjs"
  },
  "scripts": {
    "dev": "vite --mode electron",
    "dev:electron": "vite --mode electron",
    "dev:web": "vite --mode web --open /web/index.html",
    "build": "vite build --mode electron && copyfiles electron/index.html dist && copyfiles -u 1 electron/assets/** dist",
    "build:electron": "vite build --mode electron && copyfiles electron/index.html dist && copyfiles -u 1 electron/assets/** dist",
    "build:web": "vite build --mode web && copyfiles -u 1 web/assets/** dist",
    "start": "npm run build && npx electron .",
    "start:electron": "npm run build && npx electron .",
    "start:web": "vite preview --port 3000",
    "preview": "vite preview --port 3000",
    "package": "npm run build && npx electron-forge package",
    "make": "npm run build && npx electron-forge make"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/maker-deb": "^7.4.0",
    "@electron-forge/maker-rpm": "^7.4.0",
    "@electron-forge/maker-squirrel": "^7.4.0",
    "@electron-forge/maker-zip": "^7.4.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.4.0",
    "@electron-forge/plugin-fuses": "^7.4.0",
    "@electron/fuses": "^1.8.0",
    "concurrently": "^9.2.1",
    "copyfiles": "^2.4.1",
    "electron": "^40.7.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^3.0.0",
    "@pixiv/three-vrm-animation": "^3.0.0",
    "three": "^0.176.0",
    "ws": "^8.18.0"
  }
}
